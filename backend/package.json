{
  "name": "echopad-backend",
  "version": "1.0.0",
  "description": "Backend API service for Echopad connecting to CosmosDB",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build:aperio": "node scripts/build-aperio.js",
    "dev:aperio": "npm run dev --prefix ./node_modules/echopad-aperio/frontend -- --port 5174",
    "dev:aperio:backend": "cross-env NODE_ENV=development PORT=3001 node node_modules/echopad-aperio/backend/src/server.js"
  },
  "keywords": [
    "express",
    "cosmosdb",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/communication-email": "^1.0.0",
    "@azure/cosmos": "^4.0.0",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "echopad-aperio": "github:cloudsecurityweb/echopad-Aperio#dev-vk",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "html-to-text": "^9.0.5",
    "jose": "^5.2.0",
    "nunjucks": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
